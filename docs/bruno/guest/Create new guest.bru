meta {
  name: Create new guest
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/guests
  body: json
  auth: inherit
}

body:json {
  {
    "nickname": "junim pica fina",
    "avatarId": 2
  }
}

script:post-response {
  const resp = res.getBody()
  if (!resp.id) {
    throw new Error("guestId não veio na resposta")
  }
  bru.setVar("guestId", resp.id)
}

settings {
  encodeUrl: true
  timeout: 0
}
