meta {
  name: me
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/me
  body: none
  auth: bearer
}

headers {
  Authorization: {{token}}
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const resp = res.getBody()
  if (!resp.id) {
    throw new Error("userId não veio na resposta")
  }
  bru.setVar("userId", resp.id)
}
