meta {
  name: Create game session
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/game-sessions
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "name": "Jogo 10",
    "difficult": "medium"
  }
}

script:post-response {
  const resp = res.getBody()
  if (!resp.id) {
    throw new Error("sessionId não veio na resposta")
  }
  bru.setVar("sessionId", resp.id)
}

settings {
  encodeUrl: true
  timeout: 0
}
